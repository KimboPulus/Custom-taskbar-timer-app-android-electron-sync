{
  "name": "focus-timer",
  "version": "1.4.9",
  "description": "A polished local desktop timer for Windows.",
  "main": "dist-electron/electron/main.js",
  "author": "Max",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "npm run build:taskbar-helper && npm run typecheck && npm run test && npm run build:renderer && npm run build:electron",
    "build:taskbar-helper": "node tools/build-taskbar-helper.mjs",
    "build:renderer": "vite build",
    "build:electron": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "electron .",
    "package": "npm run build && electron-builder --win nsis",
    "package:portable": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "41.7.2",
    "electron-builder": "26.15.3",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "wait-on": "9.0.4"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  },
  "build": {
    "appId": "com.max.focustimer",
    "productName": "Focus Timer",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "native/bin/FocusTimerTaskbarHost.exe",
        "to": "taskbar-host/FocusTimerTaskbarHost.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Focus-Timer-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Focus Timer",
      "runAfterFinish": false,
      "deleteAppDataOnUninstall": false
    }
  }
}
